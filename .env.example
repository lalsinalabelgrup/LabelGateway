# LabelGateway — copy to .env and adjust as needed

PORT=8080
HOST=0.0.0.0
CORS_ORIGIN=*
NODE_ENV=development
# See the "Logging" section near the end of this file for LOG_* variables.

# ── Telephony provider ──────────────────────────────────────────────────────
# Options: mock | b2com | promosoft
# "mock"      → in-process simulation, no credentials needed
# "b2com"     → B2Com API/WS integration (requires B2COM_* credentials below)
# "promosoft" → PromoSoft/GUC SIP integration (requires PROMOSOFT_SIP_SERVER;
#               extension + password are sent at runtime via the login command)
TELEPHONY_PROVIDER=mock
ADAPTER=mock

# ── MockAdapter timing (ms) ─────────────────────────────────────────────────
MOCK_CONNECT_DELAY_MS=600
MOCK_CALL_CONNECT_MS=2000
MOCK_INCOMING_DELAY_MS=3000
MOCK_TRANSFER_DELAY_MS=800

# ── B2Com provider credentials ──────────────────────────────────────────────
# Required for TELEPHONY_PROVIDER=b2com.
# Leave blank to start in mock mode or to keep server running without B2Com.

# API base URL (REST)
B2COM_BASE_URL=

# WebSocket URL for real-time events
B2COM_WS_URL=

# WebRTC signalling URL (used by LabelPhone WebRTC stack — future)
B2COM_WEBRTC_URL=

# OAuth / API key authentication
B2COM_CLIENT_ID=
B2COM_TOKEN=

# Username/password authentication (alternative to token)
B2COM_USERNAME=
B2COM_PASSWORD=

# Extension / SIP domain
B2COM_DOMAIN=
B2COM_EXTENSION=

# TURN server for WebRTC (future — not used by server-side adapter)
B2COM_TURN_URL=
B2COM_TURN_USERNAME=
B2COM_TURN_PASSWORD=

# Set to true to enable verbose HTTP + WS request/response logging
B2COM_DEBUG=false

# ── PromoSoft / GUC Contact Center provider ──────────────────────────────────
# Required for TELEPHONY_PROVIDER=promosoft.
# Extension and password are NOT set here — they are sent at runtime via the
# `login` WS command from LabelPhone so credentials stay out of config files.

# SIP registrar hostname (e.g. prelabel2.guccontactcenter.com)
PROMOSOFT_SIP_SERVER=

# SIP port (default: 5060)
PROMOSOFT_SIP_PORT=5060

# SIP transport: udp | tcp | tls | wss  (default: udp)
PROMOSOFT_SIP_TRANSPORT=udp

# SIP domain / realm — leave blank to use PROMOSOFT_SIP_SERVER as the domain
PROMOSOFT_SIP_DOMAIN=

# STUN server for external IP/NAT discovery (e.g. stun.3cx.com)
# Used to populate Via and Contact headers with the public address when
# LabelGateway is behind NAT. Leave blank if on the same LAN as the PBX.
PROMOSOFT_STUN_SERVER=stun.3cx.com

# Set to true to enable verbose SIP stack logging
PROMOSOFT_DEBUG=false

# ── Transport mode ────────────────────────────────────────────────────────────
# Controls which SIP client is instantiated:
#   udp  → PromoSoftSipClient — manual SIP over dgram UDP (legacy)
#   wss  → PromoSoftWssClient — JsSIP over SIP/WebSocket (target architecture)
PROMOSOFT_MODE=udp

# ── WSS / JsSIP mode (PROMOSOFT_MODE=wss) ────────────────────────────────────
#
# PROMOSOFT_WS_URL
#   WebSocket endpoint for SIP over WebSocket.
#   Asterisk/FreeSWITCH default is port 8089 with path /ws:
#     wss://prelabel2.guccontactcenter.com:8089/ws
#   The server must respond with Sec-WebSocket-Protocol: sip on upgrade.
#   If connection is refused or the protocol is wrong, LabelGateway logs the
#   exact WebSocket error and emits registrationFailed.
#
# PROMOSOFT_AUTH_USER
#   SIP authorization username sent in the REGISTER Digest challenge response.
#   Usually the same as the extension.  Leave blank to use the extension
#   value sent at runtime via the login WS command.
#
# PROMOSOFT_SIP_URI  (documentation only — not read by code)
#   The SIP URI constructed at login time: sip:<extension>@<domain>.
#   Documented here for reference; the actual value is built dynamically.
#
PROMOSOFT_WS_URL=
PROMOSOFT_AUTH_USER=
# Stable SIP Contact URI sent in REGISTER and INVITE.
# Without this, JsSIP generates a random sip:<token>@<token>.invalid;transport=ws
# which causes some PBX dashboards to show the extension as offline.
# Set to: sip:<extension>@<host>;transport=ws
PROMOSOFT_CONTACT_URI=

# ── RTP media NAT ────────────────────────────────────────────────────────────
# Required when LabelGateway is behind NAT and the PromoSoft PBX is on the
# public internet (typical office/home deployment).
#
# PROMOSOFT_PUBLIC_RTP_IP
#   The public-facing IP address that Asterisk/PromoSoft will send RTP packets
#   to.  This is what goes in the SDP answer's c= and m=audio lines.
#   Your router MUST forward UDP traffic on ports PORT_MIN–PORT_MAX from this
#   public IP to the local machine running LabelGateway.
#   Windows Firewall MUST also allow those UDP ports inbound.
#   Leave blank only if LabelGateway and the PBX are on the same LAN (no NAT).
#
# PROMOSOFT_LOCAL_SIP_IP (informational)
#   The LAN IP address the SIP/RTP sockets bind to locally.  Usually auto-
#   detected by the SIP client; document it here for reference.
#
# PROMOSOFT_RTP_PORT_MIN / PROMOSOFT_RTP_PORT_MAX
#   Inclusive port range used for per-call RTP UDP sockets.  Each inbound call
#   claims one port from this range.  Keep the range at least as wide as the
#   maximum number of simultaneous inbound calls you expect.
#   Ports must be forwarded (router) and allowed (firewall) for inbound RTP
#   to reach LabelGateway.
#
# NOTE: If no public IP / port forwarding is available (e.g. double-NAT,
#   carrier-grade NAT), inbound RTP cannot work directly over UDP.  In that
#   case a TURN server or an RTP proxy (e.g. rtpengine, rtpproxy) is required.
#
PROMOSOFT_PUBLIC_RTP_IP=
PROMOSOFT_LOCAL_SIP_IP=
PROMOSOFT_RTP_PORT_MIN=20000
PROMOSOFT_RTP_PORT_MAX=20100

# ── Logging ───────────────────────────────────────────────────────────────────
# Central Winston logger (src/utils/logger.js).

# Minimum level written to any transport: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Console transport (human-readable, colorized)
LOG_CONSOLE=true

# Persistent file transports: logs/application-%DATE%.log (all levels) and
# logs/error-%DATE%.log (errors only), both daily-rotated and gzip-archived.
LOG_TO_FILE=true
LOG_DIR=logs
LOG_RETENTION_DAYS=14
LOG_MAX_SIZE=20m

# Verbose per-packet RTP diagnostics (sequence, timestamp, lateness, queue depth).
# Leave false in normal operation — RTP runs every 20ms and would flood the logs.
# Session start/close, pacing summaries, and errors are always logged regardless.
LOG_RTP=false

# Write raw SIP messages (REGISTER/INVITE/180/200 OK/ACK/BYE/CANCEL) to logs/sip/,
# with Authorization/Proxy-Authorization headers and digest response values
# redacted before writing. Supersedes/ORs with the legacy PROMOSOFT_SIP_DUMP.
LOG_SIP_RAW=false

# Recommended production values:
#   LOG_LEVEL=info
#   LOG_CONSOLE=true
#   LOG_TO_FILE=true
#   LOG_RTP=false

# ── RTP audio jitter buffer ───────────────────────────────────────────────────
# Smooths bursty browser-mic audio (ScriptProcessor delivers ~4 frames at once
# every ~85ms) against the RTP loop's fixed 1-frame/20ms send cadence.
# See PromoSoftSipClient.js sendAudioFrame() / _startRtpMediaLoop().

# Max frames the outbound queue may hold before oldest frames are dropped as
# overflow. Must comfortably exceed one browser burst (~4 frames).
RTP_AUDIO_QUEUE_MAX_FRAMES=25

# Frames to accumulate before the RTP loop first starts draining the queue
# (the initial startup pre-buffer). 10 frames = 200ms, sized to absorb one
# full ~85ms ScriptProcessor/AudioWorklet burst plus margin for WS/scheduler
# jitter without adding excessive one-way latency.
RTP_AUDIO_QUEUE_START_FRAMES=10

# After a mid-call underrun, frames to re-accumulate before the RTP loop
# resumes draining the queue (a smaller "recovery" threshold than the initial
# prime, since the call is already flowing — just needs to catch back up
# without immediately re-underrunning on the very next tick). 4 frames = 80ms.
RTP_AUDIO_QUEUE_RECOVERY_FRAMES=4

# A queued frame older than this (ms) is treated as stale and discarded rather
# than sent, so the queue can never silently grow into perceptible added delay.
RTP_AUDIO_QUEUE_MAX_LATENCY_MS=200

# Max consecutive concealment frames sent during an underrun before falling
# back to true silence (see _buildConcealmentFrame in PromoSoftSipClient.js).
# 4 frames = 80ms of attenuated repeated audio, then true silence — kept
# conservative since longer concealment runs are audible as robotic
# repetition even with attenuation. Raise if real-call testing shows this
# falls back to silence too eagerly on brief jitter.
RTP_AUDIO_CONCEALMENT_MAX_FRAMES=4
