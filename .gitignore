# ==========================================================
# LabelSuite - .gitignore
# ==========================================================

# ----------------------------------------------------------
# Node.js
# ----------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json

# ----------------------------------------------------------
# Environment
# ----------------------------------------------------------
.env
.env.*
!.env.example

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
logs/
*.log

# ----------------------------------------------------------
# Runtime
# ----------------------------------------------------------
pids/
*.pid
*.seed
*.pid.lock

# ----------------------------------------------------------
# Coverage
# ----------------------------------------------------------
coverage/
.nyc_output/

# ----------------------------------------------------------
# Build
# ----------------------------------------------------------
dist/
build/
out/

# ----------------------------------------------------------
# Cache
# ----------------------------------------------------------
.cache/
.parcel-cache/
.tmp/
temp/
tmp/

# ----------------------------------------------------------
# VSCode
# ----------------------------------------------------------
.vscode/*
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/settings.json

# ----------------------------------------------------------
# JetBrains
# ----------------------------------------------------------
.idea/

# ----------------------------------------------------------
# OS
# ----------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ----------------------------------------------------------
# Certificates / Keys
# ----------------------------------------------------------
*.pem
*.key
*.crt
*.pfx
*.p12

# ----------------------------------------------------------
# Secrets
# ----------------------------------------------------------
*.secret
*.secrets
*.token

# ----------------------------------------------------------
# Debug
# ----------------------------------------------------------
*.dmp

# ----------------------------------------------------------
# Local databases
# ----------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# ----------------------------------------------------------
# Temporary files
# ----------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig

# ----------------------------------------------------------
# Prompt exports (optional)
# ----------------------------------------------------------
# prompts/

# ----------------------------------------------------------
# Documentation generated locally
# ----------------------------------------------------------
docs/generated/

# ----------------------------------------------------------
# Test outputs
# ----------------------------------------------------------
test-results/
playwright-report/

# ----------------------------------------------------------
# Uploads
# ----------------------------------------------------------
uploads/